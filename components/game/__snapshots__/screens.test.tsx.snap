// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`game screen snapshots > BettingScreen 1`] = `
<section
  class="screen"
  id="screen-betting"
>
  <header
    class="screen-header"
  >
    <h2>
      PLACE YOUR BETS
    </h2>
    <p
      class="sub"
      id="betting-turn-label"
    >
      Player 1's turn
    </p>
  </header>
  <div
    class="betting-layout"
  >
    <div
      class="snail-odds"
      id="snail-odds"
    />
    <div
      class="bet-panel"
    >
      <p
        class="bet-player"
        id="bet-player-name"
      >
        —
      </p>
      <p
        class="bet-bank"
        id="bet-bank"
      >
        Shells: 100
      </p>
      <label
        class="field"
      >
        <span>
          SNAIL
        </span>
        <select
          id="bet-snail"
        />
      </label>
      <label
        class="field"
      >
        <span>
          AMOUNT
        </span>
        <input
          id="bet-amount"
          min="1"
          step="1"
          type="number"
          value="10"
        />
      </label>
      <div
        class="chip-row"
      >
        <button
          class="chip"
          data-amt="5"
          type="button"
        >
          5
        </button>
        <button
          class="chip"
          data-amt="10"
          type="button"
        >
          10
        </button>
        <button
          class="chip"
          data-amt="25"
          type="button"
        >
          25
        </button>
        <button
          class="chip"
          data-amt="50"
          type="button"
        >
          50
        </button>
        <button
          class="chip"
          data-amt="all"
          type="button"
        >
          ALL IN
        </button>
      </div>
      <button
        class="btn btn-primary"
        id="btn-lock-bet"
      >
        LOCK BET
      </button>
      <p
        class="hint"
        id="bet-hint"
      >
        Pick a snail. Odds pay if they finish 1st.
      </p>
    </div>
  </div>
  <div
    class="bets-placed"
    id="bets-placed"
  />
</section>
`;

exports[`game screen snapshots > LobbyScreen 1`] = `
<section
  class="screen"
  id="screen-lobby"
>
  <header
    class="screen-header"
  >
    <h2>
      PLAYER LOBBY
    </h2>
    <p
      class="sub"
    >
      Each racer starts with 
      <span
        class="gold"
      >
        100
      </span>
       shells
    </p>
  </header>
  <div
    class="lobby-list"
    id="lobby-list"
  />
  <div
    class="lobby-actions"
  >
    <button
      class="btn"
      id="btn-add-player"
    >
      + ADD PLAYER
    </button>
    <button
      class="btn btn-primary"
      disabled=""
      id="btn-to-betting"
    >
      GO TO BETTING →
    </button>
  </div>
</section>
`;

exports[`game screen snapshots > MuteButton 1`] = `
<button
  class="mute-btn"
  id="btn-mute"
  title="Toggle sound"
  type="button"
>
  SFX: ON
</button>
`;

exports[`game screen snapshots > RaceScreen 1`] = `
<section
  class="screen"
  id="screen-race"
>
  <header
    class="race-hud"
  >
    <div
      class="hud-left"
    >
      <span
        class="hud-label"
      >
        LAP
      </span>
      <span
        id="hud-progress"
      >
        0%
      </span>
    </div>
    <div
      class="hud-center"
    >
      <div
        class="commentary-box"
      >
        <span
          class="comm-label"
        >
          COMM
        </span>
        <span
          class="hud-event"
          id="hud-event"
        >
          READY…
        </span>
      </div>
    </div>
    <div
      class="hud-right"
    >
      <span
        class="hud-label"
      >
        TIME
      </span>
      <span
        id="hud-time"
      >
        0.0s
      </span>
    </div>
  </header>
  <canvas
    height="480"
    id="race-canvas"
    width="960"
  />
  <div
    class="lane-legend"
    id="lane-legend"
  />
</section>
`;

exports[`game screen snapshots > ResultsScreen 1`] = `
<section
  class="screen"
  id="screen-results"
>
  <header
    class="screen-header"
  >
    <h2>
      RACE RESULTS
    </h2>
    <p
      class="sub"
      id="winner-banner"
    >
      —
    </p>
  </header>
  <div
