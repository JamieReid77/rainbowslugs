    />
  </div>
  <div
    class="standings"
    id="standings"
  />
  <div
    class="lobby-actions"
  >
    <button
      class="btn btn-primary"
      id="btn-rematch"
    >
      NEXT RACE
    </button>
    <button
      class="btn"
      id="btn-new-game"
    >
      NEW GAME
    </button>
  </div>
</section>
`;

exports[`game screen snapshots > TitleScreen 1`] = `
<section
  class="screen active"
  id="screen-title"
>
  <div
    class="title-wrap"
  >
    <p
      class="blink coin-insert"
    >
      ★ AMIGA DISK 1 ★
    </p>
    <h1
      class="logo"
    >
      <span
        class="logo-slug"
      >
        RAINBOW
      </span>
      <span
        class="logo-arena"
      >
        SLUGS
      </span>
    </h1>
    <p
      class="tagline"
    >
      90s AMIGA · RAINBOW GARDEN RACE
    </p>
    <div
      aria-hidden="true"
      class="title-snails"
    >
      <div
        class="pixel-snail s1"
      />
      <div
        class="pixel-snail s2"
      />
      <div
        class="pixel-snail s3"
      />
    </div>
    <p
      class="cast-line"
    >
      ZIPPY · GEORGE · BUNGLE · GEOFFREY · JANE · FREDDY
    </p>
    <button
      class="btn btn-primary"
      id="btn-start"
    >
      PRESS START
    </button>
    <p
      class="hint"
    >
      2–6 local players · bet · watch the garden chaos
    </p>
  </div>
</section>
`;
